# DashScope（通义千问）OpenAI 兼容模式配置
# 复制本文件为 .env 并填入真实值：cp .env.example .env

# DashScope 的 API Key（在阿里云百炼控制台获取）
OPENAI_API_KEY=your_dashscope_api_key_here

# OpenAI 兼容接口地址
OPENAI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名：qwen-coder-turbo / qwen-plus / qwen-max 等
MODEL_NAME=qwen-coder-turbo
